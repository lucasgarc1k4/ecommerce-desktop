          <TableColumn fx:id="colCategoria" prefWidth="175.0" text="Categoria" />
            <TableColumn fx:id="colPreco" minWidth="0.0" prefWidth="148.0" text="Preco" />
            <TableColumn fx:id="colQuantidade" minWidth="0.0" prefWidth="151.0" text="quantidade" />
            <TableColumn fx:id="colAtivo" prefWidth="81.0" text="Ativo" />
        </columns>
      </TableView>
   </center>
</BorderPane>
