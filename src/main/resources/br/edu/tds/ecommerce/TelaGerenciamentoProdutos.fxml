<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.tds.ecommerce.TelaGerenciamentoProdutosController">
   <top>
      <HBox alignment="CENTER" prefHeight="60.0" prefWidth="600.0" style="-fx-background-color: #FF9933;" BorderPane.alignment="CENTER">
         <children>
            <Label alignment="CENTER" prefHeight="29.0" prefWidth="570.0" style="-fx-background-color: #FF9933; -fx-font-weight: 900;" text="GERENCIAMENTO DE PRODUTOS" textFill="WHITE" />
         </children>
      </HBox>
   </top>
   <bottom>
      <HBox alignment="CENTER" prefHeight="61.0" prefWidth="600.0" style="-fx-spacing: 30;" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" style="-fx-background-color: #FF9933;" text="NOVO" textFill="WHITE" />
            <Button mnemonicParsing="false" style="-fx-background-color: #3c9a4a;" text="EDITAR" textFill="WHITE" />
            <Button mnemonicParsing="false" style="-fx-background-color: #d33030;" text="EXCLUIR" textFill="WHITE" />
         </children>
      </HBox>
   </bottom>
