<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.tds.ecommerce.TelaGerenciamentoUsuariosController">
   <top>
      <HBox alignment="CENTER" prefHeight="60.0" prefWidth="600.0" style="-fx-background-color: #FF9933;" BorderPane.alignment="CENTER">
         <children>
            <Label alignment="CENTER" prefHeight="29.0" prefWidth="570.0" style="-fx-background-color: #FF9933; -fx-font-weight: 900;" text="GERENCIAMENTO DE USUARIOS" textFill="WHITE" />
         </children>
      </HBox>
   </top>
   <bottom>
      <HBox alignment="CENTER" prefHeight="61.0" prefWidth="600.0" style="-fx-spacing: 30;" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#abrirTelaCadastroUsuario" style="-fx-background-color: #FF9933;" text="NOVO" textFill="WHITE" />
            <Button mnemonicParsing="false" onAction="#editarUsuario" style="-fx-background-color: #3c9a4a;" text="EDITAR" textFill="WHITE" />
            <Button mnemonicParsing="false" onAction="#excluirUsuario" style="-fx-background-color: #d33030;" text="EXCLUIR" textFill="WHITE" />
         </children>
      </HBox>
   </bottom>
   <center>
      <TableView fx:id="tabelaUsuarios" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="colNomeCompleto" prefWidth="151.0" text="Nome Completo" />
          <TableColumn fx:id="colNomeUsuario" prefWidth="144.0" text="Usuario" />
            <TableColumn fx:id="colEmail" prefWidth="151.0" text="Email" />
            <TableColumn fx:id="colCPF" minWidth="0.0" prefWidth="153.0" text="CPF" />
        </columns>
      </TableView>
   </center>
</BorderPane>
